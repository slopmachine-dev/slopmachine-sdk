{
  "name": "slopmachine-sdk-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "build": "npm run sync-version && npm run build --workspaces --if-present",
    "build:packages": "npm run sync-version && npm run build --workspace=packages/demo-shared --workspace=packages/core --workspace=packages/react --workspace=packages/svelte --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "dev:react": "npm run dev --workspace=apps/demo-react",
    "dev:svelte": "npm run dev --workspace=apps/demo-svelte",
    "docs:dev": "npm run dev --workspace=apps/docs",
    "build:react": "npm run build --workspace=apps/demo-react",
    "build:svelte": "npm run build --workspace=apps/demo-svelte",
    "docs:build": "npm run build --workspace=apps/docs"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0"
  },
  "license": "MIT"
}
